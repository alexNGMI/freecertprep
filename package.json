{
  "name": "freecertprep",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:practice107": "npm run dev --workspace @freecertprep/practice107",
    "build": "vite build",
    "build:practice107": "npm run build --workspace @freecertprep/practice107",
    "build:all": "npm run build && npm run build:practice107",
    "deploy:cloudflare": "wrangler deploy",
    "deploy:cloudflare:preview": "wrangler versions upload --assets=./dist",
    "deploy:practice107": "npm run deploy:cloudflare --workspace @freecertprep/practice107",
    "deploy:practice107:preview": "npm run deploy:cloudflare:preview --workspace @freecertprep/practice107",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:practice107": "npm run test --workspace @freecertprep/practice107",
    "test:watch": "vitest",
    "validate:content": "vitest run src/__tests__/content-sanity.test.js",
    "audit:aplus": "node scripts/audit_aplus_structured_quality.mjs",
    "audit:aplus:ledger": "node scripts/audit_aplus_structured_quality.mjs --write-ledgers",
    "enrich:aplus-pbqs": "node scripts/enrich_aplus_pbqs.mjs",
    "enrich:netplus-practicals": "node scripts/enrich_netplus_practicals.mjs",
    "audit:netplus": "node scripts/audit_netplus_quality.mjs",
    "enrich:secplus-practicals": "node scripts/enrich_secplus_practicals.mjs",
    "audit:secplus": "node scripts/audit_secplus_quality.mjs",
    "enrich:terraform": "node scripts/enrich_terraform_learning_value.mjs",
    "generate:splunk": "node scripts/generate_splunk_core_user_questions.mjs",
    "audit:terraform": "node scripts/audit_terraform_objective_coverage.mjs",
    "audit:comptia-objectives": "node scripts/audit_comptia_objective_coverage.mjs",
    "audit:clf-c02": "node scripts/audit_clf_c02_quality.mjs",
    "audit:saa-c03": "node scripts/audit_saa_c03_quality.mjs",
    "audit:splunk": "node scripts/audit_splunk_quality.mjs",
    "audit:ccst": "node scripts/audit_ccst_networking_quality.mjs",
    "repair:ccst": "node scripts/repair_ccst_networking_quality.mjs",
    "audit:distractors": "node scripts/audit_distractor_ambiguity.mjs",
    "audit:aws-freshness": "node scripts/audit_aws_service_freshness.mjs",
    "verify:quality": "npm run lint && npm test && npm run test:practice107 && npm run build && npm run build:practice107 && npm audit --omit=dev && npm run audit:aplus && npm run audit:netplus && npm run audit:secplus && npm run audit:terraform && npm run audit:comptia-objectives && npm run audit:clf-c02 && npm run audit:saa-c03 && npm run audit:splunk && npm run audit:ccst && npm run audit:distractors && npm run audit:aws-freshness",
    "smoke:browser": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.103.0"
  }
}
